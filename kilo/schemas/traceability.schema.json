{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraceabilityReport",
  "type": "object",
  "required": [
    "artifact_id",
    "run_id",
    "commit_hash",
    "timestamp",
    "change_class",
    "risk_level",
    "workflow_state",
    "structural_truth",
    "behavioral_truth",
    "verification_truth",
    "architecture_drift",
    "final_decision"
  ],
  "properties": {
    "artifact_id": { "type": "string" },
    "run_id": { "type": "string" },
    "parent_artifact": { "type": "string" },
    "derived_from": { "type": "string" },
    "commit_hash": { "type": "string" },
    "graph_snapshot": { "type": "string" },
    "alloy_validation": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent_version": { "type": "string" },
    "prompt": { "type": "string" },
    "change_class": {
      "type": "string",
      "enum": ["CLASS_0", "CLASS_1", "CLASS_2", "CLASS_3"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MODERATE", "HIGH", "CRITICAL"]
    },
    "workflow_state": {
      "type": "string",
      "enum": ["GROUNDING", "DEBUGGING", "IMPLEMENTATION", "VERIFICATION", "PASSED", "FAILED", "BLOCKED"]
    },
    "structural_truth": {
      "type": "object",
      "required": ["impacted_files", "drift_result"],
      "properties": {
        "graph_snapshot_id": { "type": "string" },
        "joern_status": {
          "type": "string",
          "enum": ["AVAILABLE", "DEGRADED", "DEGRADED_WITH_CONSENT", "UNAVAILABLE"]
        },
        "degraded_mode_reason": { "type": "string" },
        "impacted_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "impacted_symbols": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_files_touched": {
          "type": "array",
          "items": { "type": "string" }
        },
        "drift_result": {
          "type": "string",
          "enum": ["NONE", "EXPECTED", "REVIEW_REQUIRED", "CRITICAL"]
        },
        "drift_assessment": { "type": "string" },
        "added_nodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "removed_nodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "new_external_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "behavioral_truth": {
      "type": "object",
      "required": ["alloy_model", "assertions", "all_assertions_pass"],
      "properties": {
        "alloy_model": { "type": "string" },
        "alloy_validation_id": { "type": "string" },
        "assertions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "all_assertions_pass": { "type": "boolean" },
        "scenarios": { "type": "string" },
        "model_fixes_applied": {
          "type": "array",
          "items": { "type": "string" }
        },
        "counterexamples": {
          "type": "array",
          "items": { "type": "object" }
        },
        "formal_model_weakened": {
          "type": "boolean",
          "description": "Set to true if any fact or assertion was removed or relaxed. Model fixes that add constraints or fix syntax are NOT weakening."
        },
        "model_modified_in_verification": {
          "type": "boolean",
          "description": "If true, the verification session modified the Alloy model. This triggers mandatory RETURN_TO_GROUNDING per enforcement rules."
        }
      }
    },
    "verification_truth": {
      "type": "object",
      "required": ["tests_run", "all_tests_pass", "typecheck_pass"],
      "properties": {
        "tests_run": {
          "type": "array",
          "items": { "type": "string" }
        },
        "all_tests_pass": { "type": "boolean" },
        "lint_pass": {
          "type": "boolean",
          "description": "Passed; null means lint was skipped (no config) or not applicable"
        },
        "typecheck_pass": { "type": "boolean" },
        "security_scan_pass": { "type": "boolean" },
        "build_pass": { "type": "boolean" },
        "unit_tests_new": { "type": "string" },
        "unit_tests_existing": { "type": "string" },
        "unit_tests_total": { "type": "string" },
        "typecheck": { "type": "string" },
        "build": { "type": "string" },
        "security_audit": { "type": "string" },
        "architecture_drift": { "type": "string" },
        "ci_status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "SKIPPED"]
        },
        "coverage": { "type": "string" }
      }
    },
    "code_changes": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        {
          "type": "object",
          "properties": {
            "files_modified": { "type": "array", "items": { "type": "string" } },
            "files_created": { "type": "array", "items": { "type": "string" } },
            "alloy_fixes": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "architecture_drift": {
      "type": "string",
      "enum": ["NONE", "EXPECTED", "REVIEW_REQUIRED", "CRITICAL"]
    },
    "architecture_drift_result": {
      "type": "string",
      "enum": ["NONE", "EXPECTED", "REVIEW_REQUIRED", "CRITICAL"]
    },
    "assumptions_resolved": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "confidence": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "sign_off": { "type": "string" }
        }
      }
    },
    "human_approval": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "reasons": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    },
    "final_decision": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "replay_inputs": {
      "type": "object",
      "properties": {
        "original_prompt": { "type": "string" },
        "verification_prompt": { "type": "string" },
        "commit_hash": { "type": "string" },
        "graph_snapshot": { "type": "string" },
        "graph_snapshot_id": { "type": "string" },
        "alloy_models": {
          "type": "array",
          "items": { "type": "string" }
        },
        "alloy_model_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mcp_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mcp_tool_outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mcp_tool_versions": {
          "type": "object",
          "description": "Tool versions at time of verification. Required for freshness TTL replay.",
          "properties": {
            "alloy": { "type": "string" },
            "joern": { "type": "string" },
            "vitest": { "type": "string" },
            "tsc": { "type": "string" },
            "next": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        },
        "fixture_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fixtures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "test_commands": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
